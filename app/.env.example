# Copy to .env.local and fill in. .env.local is gitignored.

# Clerk — publishable key is safe in the client.
# Dashboard: https://dashboard.clerk.com → your instance → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Supabase — publishable key is safe in the client (RLS enforces access).
# Dashboard: https://supabase.com/dashboard → project → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
